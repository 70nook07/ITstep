<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvaloniaApplication2.MainWindow"
        Title="Linux Task Manager"
        Width="1100"
        Height="600"
        CanResize="True">
    <DockPanel>
        <!-- Top -->
        <Border DockPanel.Dock="Top" Background="Black" Padding="5">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="RefreshButton" Content="Refresh Now" MinWidth="90" />
                <Button x:Name="SigTermButton" Content="SIGTERM" MinWidth="80" />
                <Button x:Name="SigKillButton" Content="SIGKILL" MinWidth="80" />
                <Button x:Name="DetailsButton" Content="Details" MinWidth="80" />
                <Button x:Name="LaunchButton" Content="Launch Process" MinWidth="100" />
                <Separator Background="Gray" Width="2" Margin="5,0" />
                <TextBlock Text="Auto-refresh:" VerticalAlignment="Center" />
                <ComboBox x:Name="IntervalCombo" SelectedIndex="1" Width="100">
                    <ComboBoxItem>1 sec</ComboBoxItem>
                    <ComboBoxItem>2 sec</ComboBoxItem>
                    <ComboBoxItem>5 sec</ComboBoxItem>
                    <ComboBoxItem>Paused</ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Status -->
        <TextBlock x:Name="StatusText"
                   DockPanel.Dock="Top"
                   Margin="10,5,10,5"
                   FontStyle="Italic"
                   Foreground="DimGray" />

        <!-- Columns -->
        <Border DockPanel.Dock="Top"
                Background="Gray"
                Padding="5"
                Margin="10,0,10,5">
            <Grid ColumnDefinitions="100, 60, 200, 90, 70, 100, 80">
                <TextBlock Grid.Column="0" FontWeight="Bold" Foreground="White" Text="Process Name" />
                <TextBlock Grid.Column="1" FontWeight="Bold" Foreground="White" Text="PID" />
                <TextBlock Grid.Column="2" FontWeight="Bold" Foreground="White" Text="Start Time" />
                <TextBlock Grid.Column="3" FontWeight="Bold" Foreground="White" Text="State" />
                <TextBlock Grid.Column="4" FontWeight="Bold" Foreground="White" Text="Priority" />
                <TextBlock Grid.Column="5" FontWeight="Bold" Foreground="White" Text="Memory (KB)" />
                <TextBlock Grid.Column="6" FontWeight="Bold" Foreground="White" Text="Threads" />
            </Grid>
        </Border>

        <!-- Processes -->
        <ListBox x:Name="ProcessesList"
                 Margin="10,0,10,10"
                 SelectionMode="Single"
                 Background="Gray">
            <ListBox.ItemTemplate>
                <DataTemplate x:CompileBindings="False">
                    <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="5">
                        <Grid ColumnDefinitions="100, 60, 200, 90, 70, 100, 80">
                            <TextBlock Grid.Column="0" Foreground="White" Text="{Binding Name}" 
                                       TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Name}" />
                            <TextBlock Grid.Column="1" Foreground="White" Text="{Binding Pid}" />
                            <TextBlock Grid.Column="2" Foreground="White" Text="{Binding StartTime}" />
                            <TextBlock Grid.Column="3" Foreground="White" Text="{Binding Status}" />
                            <TextBlock Grid.Column="4" Foreground="White" Text="{Binding Priority}" />
                            <TextBlock Grid.Column="5" Foreground="White" Text="{Binding MemoryKB}" />
                            <TextBlock Grid.Column="6" Foreground="White" Text="{Binding ThreadCount}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>